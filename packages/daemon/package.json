{
  "name": "@chord/daemon",
  "version": "0.0.1",
  "private": true,
  "description": "Chord worker daemon — listens on Arc for MilestoneAssigned, spawns a local coding-agent CLI, submits deliverable on-chain.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "pm": "tsx src/index.ts --pm",
    "bootstrap-sca": "tsx src/bootstrap-sca.ts",
    "check-types": "tsc --noEmit",
    "smoke": "tsx scripts/smoke-test.ts",
    "smoke-contract": "tsx scripts/smoke-contract-fetch.ts"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^10.3.1",
    "@circle-fin/smart-contract-platform": "^10.3.1",
    "abitype": "^1.0.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "viem": "^2.21.0",
    "which": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/which": "^3.0.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
