# Copy to packages/daemon/.env and fill in.

# --- Arc chain ---
ARC_TESTNET_RPC_URL=
CHORD_ESCROW_ADDRESS=        # populated after `yarn deploy --network arcTestnet`

# --- Circle Programmable Wallets (Dev-Controlled SCAs) ---
# Get an API key at https://console.circle.com (Sandbox environment).
CIRCLE_API_KEY=
# 32-byte hex secret, generated once and registered with Circle. Treat like a root credential.
CIRCLE_ENTITY_SECRET=
# The wallet set holding your SCAs. Created by `bootstrap-sca.ts` on first run.
CIRCLE_WALLET_SET_ID=
# This daemon's SCA wallet ID inside the set. Pasted from `bootstrap-sca.ts` output.
CIRCLE_WALLET_ID=

# --- Daemon identity ---
CHORD_DAEMON_NAME=specialist-react      # friendly label for logs / dashboard

# --- Optional ---
CHORD_AGENT_CLI=                        # absolute path; auto-discovered from PATH if unset
CHORD_HTTP_PORT=7717                    # SSE dashboard at http://localhost:<port>
CHORD_DATA_DIR=.chord                   # where milestone working dirs + state live
